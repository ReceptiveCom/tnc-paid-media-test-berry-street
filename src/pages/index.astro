---
import Layout from "../layouts/Layout.astro";
const IMG = import.meta.env.DEV ? "/images" : "/c/berry-street/images";
---

<Layout
  title="Top Nutrition Coaching vs. Berry Street | Side-by-side comparison"
  description="Considering Berry Street? Compare dietitian vetting, insurance verification, and provider continuity side by side. Your exact cost confirmed before you book."
>
  <Fragment slot="head">
    <link rel="canonical" href="https://www.topnutritioncoaching.com/c/berry-street" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  </Fragment>

  <!-- HERO -->
  <section class="bs-hero">
    <div class="bs-container">
      <div class="bs-hero-inner">

        <div class="bs-hero-text">
          <div class="bs-hero-badge">
            <span class="bs-t-eyebrow">Comparing Dietitian Platforms</span>
          </div>

          <h1 class="bs-t-h1 bs-hero-title">
            Top Nutrition Coaching<br>vs. Berry Street
          </h1>

          <p class="bs-hero-subtitle">
            We accept 1.7% of dietitians who apply. We confirm your exact cost before you book. And you work with the same RD every session.
          </p>

          <div class="bs-hero-ctas">
            <a href="https://www.topnutritioncoaching.com/quiz-insurance" class="bs-btn bs-btn-primary bs-btn-lg">Find my dietitian</a>
            <a href="#comparison" class="bs-btn bs-btn-secondary">See the comparison ↓</a>
          </div>
        </div>

        <div>
          <div class="bs-hero-vs-card">
            <div class="bs-vs-pill">
              <div class="bs-vs-pill-tnc">
                <img src="https://cdn.prod.website-files.com/626655ea8f0a3b341e18674a/6703d9fe64c092cc8093fd59_Logo%20TNC.svg" alt="Top Nutrition Coaching" style="height:36px;filter:brightness(0) invert(1);">
              </div>
              <div class="bs-vs-pill-vs">vs.</div>
              <div class="bs-vs-pill-bs">
                <img src={`${IMG}/berry-street-logo.png`} alt="Berry Street" style="height:22px;width:auto;max-width:none;" />
              </div>
            </div>

            <div class="bs-vs-stat-row">
              <div class="bs-vs-stat">
                <div class="bs-vs-stat-number">1.7%</div>
                <div class="bs-vs-stat-label">of RDs accepted<br>into our network</div>
              </div>
              <div class="bs-vs-stat">
                <div class="bs-vs-stat-number">$0</div>
                <div class="bs-vs-stat-label">with most major<br>insurance plans</div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- INSURANCE LOGOS -->
  <div class="bs-insurer-strip">
    <div class="bs-container">
      <div class="bs-insurer-strip-inner">
        <span class="bs-insurer-label">Covered by major insurers</span>
