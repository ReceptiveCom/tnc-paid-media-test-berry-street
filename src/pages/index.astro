<script is:inline>
  // Sticky mobile CTA — JS-controlled, hidden by default
  var stickyBar = document.querySelector('.bs-sticky-cta-bar');
  var heroCtas = document.querySelector('.bs-hero-ctas');
  if (stickyBar && heroCtas && window.innerWidth < 640) {
    var observer = new IntersectionObserver(function(entries) {
      stickyBar.style.display = entries[0].isIntersecting ? 'none' : 'block';
    }, { threshold: 0 });
    observer.observe(heroCtas);
  }

  // Smooth scroll for anchor links
  document.querySelectorAll('a[href^="#"]').forEach(function(link) {
    link.addEventListener('click', function(e) {
      var target = document.querySelector(link.getAttribute('href'));
      if (target) {
        e.preventDefault();
        target.scrollIntoView({ behavior: 'smooth' });
      }
    });
  });

  // UTM passthrough — append page query params to all CTA links
  (function() {
    var params = window.location.search;
    if (!params) return;
    document.querySelectorAll('a[href*="topnutritioncoaching.com"]').forEach(function(a) {
      var url = new URL(a.href);
      new URLSearchParams(params).forEach(function(v, k) { url.searchParams.set(k, v); });
      a.href = url.toString();
    });
  })();
</script>
